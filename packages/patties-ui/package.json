{
	"name": "patties-ui",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"description": "Patties UI catalog — copy-in component source, registry, and shared helpers stamped by `patties add`. Currently private; flip `private: false` to publish to npm.",
	"exports": {
		".": "./src/index.ts",
		"./registry": "./src/registry.ts",
		"./types": "./src/types.ts",
		"./templates/*": "./templates/*"
	},
	"files": [
		"src",
		"templates",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check ."
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"devDependencies": {
		"@radix-ui/react-direction": "^1.1.0",
		"@radix-ui/react-label": "^2.1.0",
		"@radix-ui/react-separator": "^1.1.0",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.0",
		"lucide-react": "^0.400.0",
		"tailwind-merge": "^2.5.0"
	}
}

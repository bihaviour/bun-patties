{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignoreExportsUsedInFile": true,
	"workspaces": {
		".": {
			"entry": ["scripts/*.ts"]
		},
		"packages/patties": {
			"ignore": ["tests/fixtures/**"],
			"entry": [
				"src/types.ts",
				"src/cli/build.ts",
				"src/cli/dev.ts",
				"src/cli/log.ts",
				"src/agents-md/subprocess-entry.ts",
				"src/build/macros/*.ts",
				"scripts/*.ts",
				"tests/adapters/smoke-harness.ts"
			],
			"project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"]
		},
		"packages/create-patties": {
			"ignore": ["templates/**"],
			"entry": ["tests/*.test.ts"]
		}
	}
}

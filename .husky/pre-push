pending=$(find .changeset -maxdepth 1 -type f -name '*.md' ! -name 'README.md' | wc -l | tr -d ' ')

if [ "$pending" = "0" ]; then
  exit 0
fi

echo "🦋 Found $pending pending changeset(s) — bumping version..."

if ! bunx changeset version; then
  echo "❌ changeset version failed"
  exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
  git add -A
  git commit -m "chore: version bump" --no-verify
fi

echo ""
echo "✅ Version bumped and committed. Run 'git push' again to include the bump."
exit 1

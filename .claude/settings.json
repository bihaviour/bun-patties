{
	"permissions": {
		"allow": [
			"Bash(bun:*)",
			"Bash(bunx:*)",
			"Bash(patties:*)",
			"Bash(git status)",
			"Bash(git diff:*)",
			"Bash(git log:*)"
		]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{ "type": "command", "command": ".claude/hooks/biome-check.sh" }
				]
			}
		]
	}
}

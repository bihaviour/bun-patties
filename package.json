{
	"name": "bun-patties-monorepo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Workspace root for the Patties framework and scaffolder. Not published.",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"start": "bun run scripts/serve-pages.ts",
		"dev": "bun --hot scripts/serve-pages.ts",
		"test": "bun --filter './packages/*' test",
		"typecheck": "bun --filter './packages/*' typecheck",
		"lint": "biome check . && bun run scripts/check-workflow-pins.ts && bun run scripts/check-release-tag.ts",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"check": "bun run lint && bun run typecheck",
		"knip": "bunx knip",
		"generate:agents-md": "bun --filter patties generate:agents-md",
		"build:specs": "bun run scripts/build-specs.ts",
		"check:docs-links": "bun run scripts/check-docs-links.ts",
		"validate": "bun run scripts/validate.ts",
		"validate:verbose": "bun run scripts/validate.ts --verbose",
		"prepare": "husky",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "bun run scripts/check-release-tag.ts && changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@changesets/cli": "^2.31.0",
		"@types/bun": "^1.1.0",
		"husky": "^9.1.7",
		"knip": "^6.14.2",
		"typescript": "^5.5.0"
	}
}

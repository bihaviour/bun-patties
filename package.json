{
	"name": "patties",
	"version": "0.0.5",
	"type": "module",
	"description": "Bun-native full-stack meta-framework with React rendering",
	"exports": {
		".": "./src/index.ts",
		"./middleware": "./src/middleware/index.ts",
		"./server": "./src/server/index.ts",
		"./router": "./src/router/index.ts",
		"./render": "./src/render/index.tsx",
		"./client": "./src/client/index.ts",
		"./build": "./src/build/index.ts",
		"./dev": "./src/dev/index.ts",
		"./config": "./src/config/define.ts",
		"./ai": "./src/ai/index.ts",
		"./agents-md": "./src/agents-md/index.ts",
		"./plugin": "./src/plugin/index.ts"
	},
	"bin": {
		"patties": "./bin/patties.ts"
	},
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check . && bun run scripts/check-workflow-pins.ts",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"check": "biome check . && tsc --noEmit",
		"knip": "bunx knip",
		"generate:agents-md": "bun run scripts/generate-agents-md.ts",
		"check:docs-links": "bun run scripts/check-docs-links.ts",
		"validate": "bun run lint && bun run typecheck && bun run test && bun run knip",
		"prepare": "husky",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "changeset publish"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"@anthropic-ai/sdk": "^0.30.0"
	},
	"peerDependenciesMeta": {
		"@anthropic-ai/sdk": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@changesets/cli": "^2.31.0",
		"@types/bun": "latest",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"fern-api": "^5.37.9",
		"husky": "^9.1.7",
		"knip": "^6.14.2",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"typescript": "^5.5.0"
	},
	"dependencies": {
		"zod": "^4.4.3"
	},
	"workspaces": [
		"packages/*"
	]
}
